#!/usr/bin/env bash
# Pre-push gate: refuse to push work that would turn CI red.
# Install once with: git config core.hooksPath .githooks
# Bypass (emergencies only): git push with the verification flag disabled.
set -euo pipefail

# Git exports GIT_DIR (and related vars) to hooks. From a linked worktree these
# are absolute paths, so any gate test that spawns git inside a temporary
# fixture directory would operate on THIS repository instead of its fixture
# (observed: fixture commits and config written into the real repo). Scrub them
# so the gates run exactly as they do from a clean shell.
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_OBJECT_DIRECTORY GIT_COMMON_DIR GIT_PREFIX

echo "[pre-push] typecheck"
npx tsc --noEmit

echo "[pre-push] full test suite"
npx vitest run --silent

# Record which refs are being pushed (stdin is consumed here; read it once).
release_push=0
tag_push=0
pushed_branches=()
tag_shas=()
while read -r _local_ref local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/main) release_push=1; pushed_branches+=("main") ;;
    refs/heads/*) pushed_branches+=("${remote_ref#refs/heads/}") ;;
    refs/tags/*) release_push=1; tag_push=1; tag_shas+=("$local_sha") ;;
  esac
done

# The local suite above runs on ONE OS. Cross-platform jobs (Linux/macOS/Windows)
# only run in CI, so a platform-specific failure — like a POSIX-only file op that
# EPERMs on Windows, or a test whose timeout only overruns under slower Windows
# I/O — is invisible here. Actual CI conclusions are the only signal.
# Return the latest COMPLETED CI conclusion for a branch, else "none".
branch_ci_conclusion() {
  command -v gh >/dev/null 2>&1 || { echo "none"; return; }
  gh run list --branch "$1" --limit 1 --json status,conclusion \
    --jq 'if (.[0].status // "") == "completed" then (.[0].conclusion // "none") else "none" end' \
    2>/dev/null || echo "none"
}

# A red base branch cannot be run locally, so inheriting its failures via a
# merge/rebase is invisible to the suite above. Surface it loudly on every push.
main_ci=$(branch_ci_conclusion main)
if [ "$main_ci" = "failure" ]; then
  echo "[pre-push] WARNING: latest CI on origin/main is FAILING — a merge/rebase inherits its red." >&2
  echo "[pre-push]   Inspect: gh run list --branch main --limit 1" >&2
fi

# Refuse to stack more work on, or merge, a branch whose latest CI is already red
# (e.g. a platform-only failure the local suite never sees). This turns "CI went
# red and nobody noticed" into a hard stop at the next push.
for br in "${pushed_branches[@]}"; do
  [ "$br" = "main" ] && continue  # main handled by the release block below
  concl=$(branch_ci_conclusion "$br")
  if [ "$concl" = "failure" ]; then
    echo "[pre-push] ERROR: latest CI on '$br' is FAILING (includes cross-platform jobs the local suite cannot run)." >&2
    echo "[pre-push]   Inspect: gh run list --branch $br --limit 1" >&2
    echo "[pre-push]   Fix CI first. If THIS push IS the fix, re-run the push with verification disabled." >&2
    exit 1
  fi
done

# Pushing main or a tag is a release-facing action: also run the release validator.
if [ "$release_push" -eq 1 ]; then
  echo "[pre-push] release validator (main/tag push)"
  bash scripts/validate-release.sh

  # A tag must never be cut on red CI; a main push on red CI is allowed (it may BE
  # the fix) but warns loudly.
  if [ "$main_ci" = "failure" ]; then
    if [ "$tag_push" -eq 1 ]; then
      echo "[pre-push] ERROR: latest CI on origin/main is FAILING — refusing to push a tag." >&2
      echo "[pre-push] Fix CI first, or bypass knowingly by disabling push verification." >&2
      exit 1
    fi
    echo "[pre-push] WARNING: latest CI on origin/main is FAILING — this push should fix it." >&2
  fi

  # The branch check above says nothing about the commit being tagged, and it
  # treats a still-running workflow as "not failing" — which is how a tag once
  # went out while its own CI was mid-flight and about to fail on Windows. A tag
  # is a published artifact, so require the exact tagged commit to have a
  # COMPLETED, green CI run, and require that run to contain a green Windows job.
  # The local suite runs on one OS; Windows drift has no other oracle.
  for tag_sha in "${tag_shas[@]}"; do
    # An annotated tag pushes the TAG OBJECT's sha; CI runs against the commit it
    # points at. Dereference before asking about workflow runs, or every
    # annotated tag looks like a commit CI has never seen.
    sha=$(git rev-parse "${tag_sha}^{commit}" 2>/dev/null || echo "$tag_sha")
    if ! command -v gh >/dev/null 2>&1; then
      echo "[pre-push] ERROR: gh unavailable — cannot confirm CI for the tagged commit $sha." >&2
      echo "[pre-push]   Verify CI by hand, then push again with verification disabled." >&2
      exit 1
    fi
    run_id=$(gh run list --commit "$sha" --workflow ci --limit 1 \
      --json databaseId,status,conclusion \
      --jq 'if (.[0].status // "") == "completed" and (.[0].conclusion // "") == "success"
            then (.[0].databaseId | tostring) else "" end' 2>/dev/null || echo "")
    if [ -z "$run_id" ]; then
      echo "[pre-push] ERROR: no completed, successful CI run for tagged commit $sha." >&2
      echo "[pre-push]   A tag must not be cut before its own CI has finished." >&2
      echo "[pre-push]   Inspect: gh run list --commit $sha" >&2
      exit 1
    fi
    windows=$(gh run view "$run_id" --json jobs \
      --jq '[.jobs[] | select(.name | test("windows"; "i")) | .conclusion] | unique | join(",")' \
      2>/dev/null || echo "")
    if [ "$windows" != "success" ]; then
      echo "[pre-push] ERROR: CI run $run_id for $sha has no green Windows job (found: '${windows:-none}')." >&2
      echo "[pre-push]   Windows drift is invisible to the local suite; refusing to tag without it." >&2
      exit 1
    fi
    echo "[pre-push] tagged commit ${sha:0:8}: CI green including Windows"
  done
fi

echo "[pre-push] all gates passed"
